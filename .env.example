# ╔══════════════════════════════════════════════════════╗
# ║  Memory Viewer — Environment Variables               ║
# ║  Copy to .env and adjust as needed                   ║
# ║  All variables use MV_ prefix (recommended)          ║
# ║  Legacy names are also supported for backward compat ║
# ╚══════════════════════════════════════════════════════╝

# --- Service ---
# 服务端口 (legacy: MEMORY_VIEWER_PORT)
# MV_PORT=8501

# 监听地址 (legacy: MEMORY_VIEWER_HOST)
# MV_HOST=0.0.0.0

# --- Paths ---
# agentmemory 缓存文件路径 (legacy: AGENTMEMORY_CACHE)
# MV_AGENTMEMORY_CACHE=./data/cache/agentmemory.json

# Hermes 记忆目录 (legacy: HERMES_MEMORIES_DIR)
# MV_HERMES_MEMORIES_DIR=./data/memories

# Hermes Profile 目录 (legacy: HERMES_PROFILES_DIR)
# MV_HERMES_PROFILES_DIR=./data/profiles

# 备份目录 (legacy: BACKUP_DIR)
# MV_BACKUP_DIR=./data/backups

# 版本历史目录 (legacy: VERSIONS_DIR)
# MV_VERSIONS_DIR=./data/versions

# --- Cache ---
# 缓存刷新间隔，单位分钟 (legacy: CACHE_REFRESH_INTERVAL)
# MV_CACHE_REFRESH_INTERVAL=30

# --- Security ---
# CORS 允许的源，逗号分隔 (legacy: CORS_ORIGINS)
# MV_CORS_ORIGINS=http://localhost:8501,http://localhost:5173

# 审计日志路径 (legacy: AUDIT_LOG)
# MV_AUDIT_LOG=./data/cache/audit.json
