"""
Memory Viewer v2 — Backend API (FastAPI)

Endpoints:
  GET /api/agentmemory       -> {memories: [...]}
  GET /api/agentmemory/paginated -> paginated agentmemory
  GET /api/agentmemory/export -> export memories (JSON/Markdown)
  POST /api/agentmemory      -> create new memory
  POST /api/agentmemory/import -> import memories from file
  PUT /api/agentmemory/{id}  -> update memory (F-08)
  DELETE /api/agentmemory/{id} -> delete memory (F-09)
  POST /api/agentmemory/batch/delete -> batch delete (F-09)
  GET /api/hermes-memory     -> {global: {memory, user}, profiles: {...}}
  GET /api/profiles          -> ["chief-agent", "daily", ...]
  GET /api/search            -> cross-source search
  GET /api/stats             -> unified statistics (F-10)
  GET /api/health            -> service health check
"""

import logging
import time
from contextlib import asynccontextmanager
from pathlib import Path

from fastapi import FastAPI, Request
from fastapi.middleware.cors import CORSMiddleware
from fastapi.staticfiles import StaticFiles
