# Configure logging
logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(name)s] %(levelname)s: %(message)s")


@asynccontextmanager
async def lifespan(app: FastAPI):
    """FastAPI lifespan: start/stop scheduler, init adapter registry."""
    await sched.on_startup(interval_minutes=settings.CACHE_REFRESH_INTERVAL)
    # F-38: Discover plugins on startup
    discover_plugins()
    # P15: Initialize adapter registry from config
    from app.adapters.registry import init_registry_from_config
    from app.adapters import registry as reg_module
    from app.config_loader import load_config
    from pathlib import Path as _P

    cfg = load_config(_P(__file__).resolve().parent.parent.parent)
    reg_module.registry = init_registry_from_config(cfg)
    yield
    await sched.on_shutdown()


app = FastAPI(
    title="Memory Viewer API",
    description="Hermes Agent 记忆系统全景视图 API",
    version="2.2.0",
    docs_url="/api/docs",
    redoc_url="/api/redoc",
    openapi_url="/api/openapi.json",
    lifespan=lifespan,
)

# CORS
app.add_middleware(
    CORSMiddleware,
    allow_origins=settings.CORS_ORIGINS,
    allow_methods=["*"],
    allow_headers=["*"],
)

# P5: Audit middleware (JSONL logging)
app.add_middleware(AuditMiddleware)

# P5: Metrics middleware (ring buffer timing)
app.add_middleware(MetricsMiddleware)

# P9: Usage Tracker middleware (API analytics)
app.add_middleware(UsageTrackerMiddleware)

# Track startup time for health check
app.state.start_time = time.time()

# Register API routers FIRST (before catch-all)
app.include_router(agentmemory.router, prefix="/api/agentmemory", tags=["agentmemory"])
